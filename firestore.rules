rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid)) ||
        request.auth.token.email == 'gm.shreelabel@gmail.com'
      );
    }

    function hasRole(role) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roleId == role ||
        isAdmin()
      );
    }

    // --- RBAC: ROLES & PERMISSIONS ---

    match /roles/{roleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      // Allow user to write to their own profile, but only Admin can change customPermissions
      allow update: if (isAdmin() || request.auth.uid == userId) && 
                    (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['customPermissions', 'roleId']) || isAdmin());
      allow create: if isSignedIn();
    }

    // --- MASTER DATA & CONFIG ---

    match /system_settings/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /roll_settings/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /counters/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // --- CORE COLLECTIONS ---

    match /jobs/{jobId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
      
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /salesOrders/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /estimates/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /jumbo_stock/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /inventoryItems/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /alerts/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /adminUsers/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (request.auth.token.email == 'gm.shreelabel@gmail.com' && request.auth.uid == userId);
    }

    // --- FALLBACK ---

    match /{collectionName}/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
