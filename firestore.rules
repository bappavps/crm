
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Master Jobs Collection
    match /jobs/{jobId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      // Sales can only update if not yet approved
      allow update: if isAdmin() || (isSignedIn() && resource.data.salesUserId == request.auth.uid && resource.data.status == 'Pending Approval');
      allow delete: if isAdmin();

      // Technical Specifications Sub-collection
      match /technical/details {
        allow read: if isSignedIn();
        // Only editable by Admin or Designer within the 30-minute lock window
        allow write: if isAdmin() || (isSignedIn() && request.time < timestamp(resource.data.edit_lock_time));
      }

      // Financial Summary Sub-collection
      match /financial/summary {
        allow read: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/jobs/$(jobId)).data.salesUserId == request.auth.uid);
        allow write: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/jobs/$(jobId)).data.status == 'Pending Approval');
      }

      // Project Files Sub-collection
      match /files/{fileId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    match /adminUsers/{userId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin() || isOwner(userId);
    }

    match /system_settings/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /roll_settings/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /counters/{id} {
      allow get: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /{collectionName}/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
