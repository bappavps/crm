
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /adminUsers/{userId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin() || isOwner(userId);
    }

    match /jobs/{jobId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.salesUserId == request.auth.uid && resource.data.status == 'Pending Approval');
      allow delete: if isAdmin();
    }

    match /system_settings/pricing_config {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /job_settings/unique-id-config {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /roll_settings/global_config {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /counters/{id} {
      allow get: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Generic fallback for master data and other collections
    match /{collectionName}/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
