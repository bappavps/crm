
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ERP SYSTEM SECURITY RULES - PROTOTYPING PHASE
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/_system_roles/admins/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- COLLECTION RULES ---

    match /_system_roles/admins/{userId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if (isOwner(userId) || isAdmin()) && resource != null;
      allow delete: if isAdmin() && resource != null;
    }

    match /{collectionName}/{docId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin() && collectionName in [
        'customers', 'suppliers', 'unitsOfMeasure', 'machines', 
        'dies', 'plates', 'rawMaterials', 'finishedGoodDefinitions', 'defects',
        'roll_settings', 'job_settings', 'materials', 'cylinders'
      ];
    }

    match /inventoryLots/{inventoryLotId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource != null;
    }

    match /jumbo_stock/{id} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /inventoryItems/{id} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /artworks/{artworkId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uploadedByUserId == request.auth.uid;
      allow update, delete: if (isExistingOwner(resource.data.uploadedByUserId) || isAdmin());
    }

    match /estimates/{estimateId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.createdByUserId == request.auth.uid;
      allow update, delete: if (isExistingOwner(resource.data.createdByUserId) || isAdmin());
    }

    match /billsOfMaterial/{billOfMaterialId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if (isAdmin() || isExistingOwner(resource.data.createdByUserId));

      match /{sub}/{subId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if (isAdmin() || isExistingOwner(resource.data.billOfMaterialCreatedByUserId));
      }
    }

    match /salesOrders/{salesOrderId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.createdByUserId == request.auth.uid;
      allow update, delete: if (isExistingOwner(resource.data.createdByUserId) || isAdmin());

      match /items/{itemId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if (isAdmin() || isExistingOwner(resource.data.salesOrderCreatedByUserId));
      }
    }

    match /job_planning/{id} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && !resource.data.is_locked);
    }

    match /jobs/{id} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /counters/{id} {
      allow get: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /notifications/{id} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /jobCards/{jobCardId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if (isAdmin() || isOwner(resource.data.assignedOperatorId) || isOwner(resource.data.jobCardCreatedByUserId));

      match /{sub}/{subId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if (isAdmin() || isOwner(resource.data.jobCardAssignedOperatorId) || isOwner(resource.data.jobCardCreatedByUserId));
      }
    }

    match /invoices/{invoiceId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.generatedByUserId == request.auth.uid;
      allow update, delete: if (isAdmin() || isExistingOwner(resource.data.generatedByUserId));
    }

    match /dispatches/{dispatchId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.generatedByUserId == request.auth.uid;
      allow update, delete: if (isAdmin() || isExistingOwner(resource.data.generatedByUserId));

      match /packingLists/{packingListId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if (isAdmin() || isOwner(resource.data.dispatchGeneratedByUserId));
      }
    }

    match /purchaseOrders/{purchaseOrderId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.createdByUserId == request.auth.uid;
      allow update, delete: if (isAdmin() || isExistingOwner(resource.data.createdByUserId));
    }

    match /finishedGoodInventory/{id} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn() && resource != null;
    }
  }
}
