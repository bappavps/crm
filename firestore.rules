
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getAdminData() {
      return get(/databases/$(database)/documents/adminUsers/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }

    function hasRole(role) {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roleId == role;
    }

    function isMigrationLocked() {
      // Global safety lock managed by Admin in system_settings/pricing_config
      let settings = get(/databases/$(database)/documents/system_settings/pricing_config).data;
      return settings.migration_lock == true;
    }

    // --- MASTER JOBS COLLECTION ---

    match /jobs/{jobId} {
      allow read: if isSignedIn();
      
      // Allow creation if signed in and not locked
      allow create: if isSignedIn() && !isMigrationLocked();
      
      // Sales can update only if not yet approved
      allow update: if isAdmin() || (
        isSignedIn() && 
        !isMigrationLocked() &&
        resource.data.status != 'Approved' && 
        (resource.data.salesUserId == request.auth.uid || hasRole('Sales'))
      );
      
      allow delete: if isAdmin();

      // Technical Sub-collection: 30-minute Edit Lock
      match /technical/details {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && !isMigrationLocked();
        allow update: if isAdmin() || (
          isSignedIn() && 
          !isMigrationLocked() &&
          // Enforce 30-minute window from the stored lock time
          request.time < timestamp(resource.data.edit_lock_time)
        );
        allow delete: if isAdmin();
      }

      // Financial Sub-collection: Admin Only
      match /financial/summary {
        allow read: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/jobs/$(jobId)).data.salesUserId == request.auth.uid);
        allow write: if isAdmin();
      }

      // Project Files: Role-based Uploads
      match /files/{fileId} {
        allow read: if isSignedIn();
        // Allow creation if Job is not yet fully completed
        allow create: if isSignedIn() && !isMigrationLocked() && get(/databases/$(database)/documents/jobs/$(jobId)).data.status != 'Completed';
        allow update, delete: if isAdmin();
      }
    }

    // --- INVENTORY & STOCK ---

    match /jumbo_stock/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && !isMigrationLocked());
    }

    match /inventoryItems/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && !isMigrationLocked());
    }

    // --- CONFIGURATION & COUNTERS (Admin Only Write) ---

    match /system_settings/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /roll_settings/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /counters/{id} {
      allow read: if isSignedIn();
      // Allow signed-in users to update counters during Job/Roll creation transactions
      allow write: if isSignedIn() && !isMigrationLocked();
    }

    // --- USERS & ROLES ---

    match /users/{userId} {
      allow read: if isSignedIn();
      // Only Admin can change roles or metadata
      allow write: if isAdmin();
    }

    match /adminUsers/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- AUDIT LOGS (Append Only) ---

    match /job_audit_log/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && !isMigrationLocked();
      allow update, delete: if false; // Audit logs must be immutable
    }

    // --- OTHER COLLECTIONS (Fallback) ---

    match /{collectionName}/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
