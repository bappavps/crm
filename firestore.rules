rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SHREE LABEL CRM - SECURITY RULES CONFIGURATION (V2)
     * 
     * Core Philosophy:
     * Implements Role-Based Access Control (RBAC) and Database-Backed Access Control (DBAC).
     * 
     * Key Security Decisions:
     * 1. Authorization Independence: Admin status is determined by the existence of a document in 
     *    the /adminUsers collection.
     * 2. Account Status Gatekeeping: Access to system resources is predicated on the user 
     *    having 'isActive: true' in their profile.
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user is a designated system administrator. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }

    /** Checks if the authenticated user's account status is currently 'active'. */
    function isUserActive() {
      // Use get() to check user status from profile
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isActive == true;
    }

    /** Checks if the provided ID matches the authenticated user's UID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Validates ownership and ensures the document exists. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** Special override for prototype seeding/initial setup */
    function isTargetAdmin() {
      return isSignedIn() && request.auth.token.email == 'gm.shreelabel@gmail.com';
    }

    // --- Collection Rules ---

    /**
     * User Profiles: Unified management.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isAdmin() || isTargetAdmin();
      allow update: if isAdmin() || (isExistingOwner(userId) && resource.data.isActive == true);
      allow delete: if isAdmin();
    }

    /**
     * Roles: Define permissions.
     */
    match /roles/{roleId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin() || isTargetAdmin();
    }

    /**
     * Admin Markers: DBAC marker documents.
     * Users must be able to 'get' their own marker to verify admin status in UI.
     */
    match /adminUsers/{adminUid} {
      allow get: if isOwner(adminUid) || isAdmin();
      allow list: if isAdmin();
      allow write: if isAdmin() || (isOwner(adminUid) && isTargetAdmin());
    }

    /**
     * ERP Operational Modules
     */
    match /jobs/{jobId} {
      allow read, write: if isSignedIn();
      
      match /technical/{docId} { allow read, write: if isSignedIn(); }
      match /financial/{docId} { allow read, write: if isSignedIn(); }
      match /files/{docId} { allow read, write: if isSignedIn(); }
    }

    match /estimates/{id} { allow read, write: if isSignedIn(); }
    match /salesOrders/{id} { allow read, write: if isSignedIn(); }
    match /customers/{id} { allow read, write: if isSignedIn(); }
    match /materials/{id} { allow read, write: if isSignedIn(); }
    match /machines/{id} { allow read, write: if isSignedIn(); }
    match /cylinders/{id} { allow read, write: if isSignedIn(); }
    match /suppliers/{id} { allow read, write: if isSignedIn(); }
    match /jumbo_stock/{id} { allow read, write: if isSignedIn(); }
    match /inventoryItems/{id} { allow read, write: if isSignedIn(); }
    match /jobCards/{id} { allow read, write: if isSignedIn(); }
    match /boms/{id} { allow read, write: if isSignedIn(); }
    match /workOrders/{id} { allow read, write: if isSignedIn(); }
    match /qualityChecks/{id} { allow read, write: if isSignedIn(); }
    match /dispatchChallans/{id} { allow read, write: if isSignedIn(); }
    match /invoices/{id} { allow read, write: if isSignedIn(); }
    match /artworks/{id} { allow read, write: if isSignedIn(); }
    match /counters/{id} { allow read, write: if isSignedIn(); }
    match /system_settings/{id} { allow read, write: if isSignedIn(); }
    match /roll_settings/{id} { allow read, write: if isSignedIn(); }
    match /job_settings/{id} { allow read, write: if isSignedIn(); }
    match /alerts/{id} { allow read, write: if isSignedIn(); }
    match /notifications/{id} { allow read, write: if isSignedIn(); }
    
    match /system_logs/{path=**} {
      allow read, write: if isAdmin();
    }

    // --- Catch-all Default ---
    match /{path=**} {
      allow read, write: if false;
    }
  }
}