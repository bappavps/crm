
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SHREE LABEL ERP - SECURITY RULES
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }

    function isManager() {
      return isSignedIn() && exists(/databases/$(database)/documents/managerUsers/$(request.auth.uid));
    }

    function isOperator() {
      return isSignedIn() && exists(/databases/$(database)/documents/operatorUsers/$(request.auth.uid));
    }

    function isInternalStaff() {
      return isAdmin() || isManager() || isOperator();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isDataOwner(ownerIdField) {
      return isSignedIn() && request.auth.uid == resource.data[ownerIdField];
    }

    function isCreatingWithOwner(ownerIdField) {
      return isSignedIn() && request.auth.uid == request.resource.data[ownerIdField];
    }

    // --- ROLE & USER MANAGEMENT ---

    match /adminUsers/{userId} {
      allow read: if isInternalStaff() || isOwner(userId);
      allow write: if isAdmin() || (isSignedIn() && !exists(/databases/$(database)/documents/adminUsers/$(userId)));
    }
    match /managerUsers/{userId} {
      allow read: if isInternalStaff() || isOwner(userId);
      allow write: if isAdmin();
    }
    match /operatorUsers/{userId} {
      allow read: if isInternalStaff() || isOwner(userId);
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow get, list: if isInternalStaff() || isOwner(userId);
      allow create: if isOwner(userId) || isAdmin() || (isSignedIn() && !exists(/databases/$(database)/documents/adminUsers/$(userId)));
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // --- MASTER DATA & INVENTORY ---

    match /customers/{id} { allow read: if isInternalStaff(); allow write: if isInternalStaff(); }
    match /materials/{id} { allow read: if isInternalStaff(); allow write: if isInternalStaff(); }
    match /machines/{id} { allow read: if isInternalStaff(); allow write: if isInternalStaff(); }
    match /cylinders/{id} { allow read: if isInternalStaff(); allow write: if isInternalStaff(); }
    match /dies/{id} { allow read: if isInternalStaff(); allow write: if isInternalStaff(); }
    match /suppliers/{id} { allow read: if isInternalStaff(); allow write: if isInternalStaff(); }
    
    match /jumbo_stock/{id} { allow read, write: if isInternalStaff(); }
    match /inventoryItems/{id} { allow read, write: if isInternalStaff(); }

    // --- TRANSACTIONAL ---

    match /estimates/{id} { allow read, write: if isInternalStaff(); }
    match /salesOrders/{id} { allow read, write: if isInternalStaff(); }
    match /jobCards/{id} { allow read, write: if isInternalStaff(); }
    match /boms/{id} { allow read, write: if isInternalStaff(); }
    match /workOrders/{id} { allow read, write: if isInternalStaff(); }
    match /artworks/{id} { allow read, write: if isInternalStaff(); }
    match /qualityChecks/{id} { allow read, write: if isInternalStaff(); }
    match /dispatchChallans/{id} { allow read, write: if isInternalStaff(); }
    match /invoices/{id} { allow read, write: if isInternalStaff(); }
    match /purchaseOrders/{id} { allow read, write: if isInternalStaff(); }
  }
}
