
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }

    function isDesign() {
      return isSignedIn() && (exists(/databases/$(database)/documents/designUsers/$(request.auth.uid)) || isAdmin());
    }

    function isProduction() {
      return isSignedIn() && (exists(/databases/$(database)/documents/productionUsers/$(request.auth.uid)) || isAdmin());
    }

    function isInternalStaff() {
      return isAdmin() || isDesign() || isProduction() || exists(/databases/$(database)/documents/managerUsers/$(request.auth.uid)) || exists(/databases/$(database)/documents/operatorUsers/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /adminUsers/{userId} { allow read: if isInternalStaff() || isOwner(userId); allow write: if isAdmin() || (isSignedIn() && !exists(/databases/$(database)/documents/adminUsers/$(userId))); }
    match /designUsers/{userId} { allow read: if isInternalStaff(); allow write: if isAdmin(); }
    match /productionUsers/{userId} { allow read: if isInternalStaff(); allow write: if isAdmin(); }
    match /managerUsers/{userId} { allow read: if isInternalStaff(); allow write: if isAdmin(); }
    match /operatorUsers/{userId} { allow read: if isInternalStaff(); allow write: if isAdmin(); }

    match /users/{userId} {
      allow get, list: if isInternalStaff() || isOwner(userId);
      allow create: if isOwner(userId) || isAdmin() || (isSignedIn() && !exists(/databases/$(database)/documents/adminUsers/$(userId)));
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /jumbo_stock/{id} { allow read, write: if isInternalStaff(); }
    match /inventoryItems/{id} { allow read, write: if isInternalStaff(); }
    match /production_jobs/{id} { 
      allow read: if isInternalStaff(); 
      allow create, update, delete: if isDesign(); 
    }
    match /settings/{id} { allow read: if isInternalStaff(); allow write: if isAdmin(); }
    match /customers/{id} { allow read, write: if isInternalStaff(); }
    match /materials/{id} { allow read, write: if isInternalStaff(); }
    match /machines/{id} { allow read, write: if isInternalStaff(); }
    match /cylinders/{id} { allow read, write: if isInternalStaff(); }
    match /dies/{id} { allow read, write: if isInternalStaff(); }
    match /suppliers/{id} { allow read, write: if isInternalStaff(); }
    match /estimates/{id} { allow read, write: if isInternalStaff(); }
    match /salesOrders/{id} { allow read, write: if isInternalStaff(); }
    match /jobCards/{id} { allow read, write: if isInternalStaff(); }
    match /boms/{id} { allow read, write: if isInternalStaff(); }
    match /workOrders/{id} { allow read, write: if isInternalStaff(); }
    match /artworks/{id} { allow read, write: if isInternalStaff(); }
    match /qualityChecks/{id} { allow read, write: if isInternalStaff(); }
    match /dispatchChallans/{id} { allow read, write: if isInternalStaff(); }
    match /invoices/{id} { allow read, write: if isInternalStaff(); }
    match /purchaseOrders/{id} { allow read, write: if isInternalStaff(); }
  }
}
