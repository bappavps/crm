
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMasterAdmin() {
      return isSignedIn() && request.auth.token.email == 'gm.shreelabel@gmail.com';
    }

    function isAdmin() {
      return isMasterAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid)));
    }

    function isUserActive() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isMasterAdmin() || (exists(userPath) && get(userPath).data.isActive == true);
    }

    // 1. Global Admin Override - Put this FIRST
    match /{path=**} {
      allow read, write: if isMasterAdmin();
      allow read, write: if isAdmin();
    }

    // 2. Specific Collection Rules
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow write: if isAdmin() || (request.auth.uid == userId);
    }

    match /adminUsers/{id} {
      allow read, write: if isAdmin();
    }

    match /company_settings/{id} {
      allow get: if true;
      allow write: if isAdmin();
    }

    match /system_settings/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /paper_stock/{id} {
      allow get: if true;
      allow list: if isSignedIn();
      allow write: if isSignedIn() && isUserActive();
    }

    match /jumbo_job_cards/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isUserActive();
    }

    match /inventory_audits/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isUserActive();
    }

    match /machines/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /roles/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /counters/{id} {
      allow read, write: if isSignedIn();
    }

    match /planning_tables/{tableId}/{document=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isUserActive();
    }
    
    match /print_templates/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /image_library/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
