
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // DEVELOPMENT MODE: Global read/write access enabled.
    // This allows full system access without specific session verification.
    
    match /jumbo_job_cards/{document=**} {
      allow read, write: if true;
    }
    
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
