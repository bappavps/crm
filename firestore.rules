
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid)) ||
        request.auth.token.email == 'gm.shreelabel@gmail.com'
      );
    }

    function hasRole(role) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roleId == role ||
        isAdmin()
      );
    }

    function isMigrationLocked() {
      let settings = get(/databases/$(database)/documents/system_settings/pricing_config).data;
      return settings.migration_lock == true;
    }

    // --- MASTER JOBS COLLECTION ---

    match /jobs/{jobId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && !isMigrationLocked();
      allow update: if isAdmin() || (
        isSignedIn() && 
        !isMigrationLocked() &&
        resource.data.status != 'Approved' && 
        (resource.data.salesUserId == request.auth.uid || hasRole('Sales'))
      );
      allow delete: if isAdmin();

      match /technical/details {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && !isMigrationLocked();
        allow update: if isAdmin() || (
          isSignedIn() && 
          !isMigrationLocked() &&
          request.time < timestamp(resource.data.edit_lock_time)
        );
        allow delete: if isAdmin();
      }

      match /financial/summary {
        allow read: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/jobs/$(jobId)).data.salesUserId == request.auth.uid);
        allow write: if isAdmin();
      }

      match /files/{fileId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && !isMigrationLocked() && get(/databases/$(database)/documents/jobs/$(jobId)).data.status != 'Completed';
        allow update, delete: if isAdmin();
      }
    }

    // --- INVENTORY & STOCK ---

    match /jumbo_stock/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && !isMigrationLocked());
    }

    match /inventoryItems/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && !isMigrationLocked());
    }

    match /alerts/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- CONFIGURATION & COUNTERS (Admin Only Write) ---

    match /system_settings/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /roll_settings/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /counters/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && !isMigrationLocked();
    }

    // --- LOGS ---

    match /system_logs/{document=**} {
      allow read, write: if isAdmin();
    }

    // --- USERS & ROLES ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    match /adminUsers/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.auth.token.email == 'gm.shreelabel@gmail.com' && request.auth.uid == userId);
    }

    // --- OTHER COLLECTIONS (Fallback) ---

    match /{collectionName}/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
