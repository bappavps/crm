
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user within the Shree Label ERP system.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "roleId": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "username", "email", "firstName", "lastName", "roleId", "isActive", "createdAt"]
    },
    "JumboStock": {
      "title": "JumboStock",
      "description": "Stores master data for raw jumbo rolls entered via GRN.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "rollNo": { "type": "string" },
        "companyRollNo": { "type": "string" },
        "paperCompany": { "type": "string" },
        "paperType": { "type": "string" },
        "widthMm": { "type": "number" },
        "lengthMeters": { "type": "number" },
        "sqm": { "type": "number" },
        "gsm": { "type": "number" },
        "weightKg": { "type": "number" },
        "purchaseRate": { "type": "number" },
        "wastage": { "type": "number" },
        "dateOfUse": { "type": "string", "format": "date-time" },
        "receivedDate": { "type": "string", "format": "date-time" },
        "jobNo": { "type": "string" },
        "size": { "type": "string" },
        "productName": { "type": "string" },
        "code": { "type": "string" },
        "lotNumber": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "barcode": { "type": "string" },
        "status": { "type": "string", "enum": ["In Stock", "Consumed", "In Production"] },
        "createdById": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "ProductionJob": {
      "title": "ProductionJob",
      "description": "Production Planning entity based on Design department releases.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "serial_no": { "type": "string" },
        "order_date": { "type": "string", "format": "date" },
        "planning_status": { "type": "string" },
        "plate_no": { "type": "string" },
        "job_name": { "type": "string" },
        "label_size": { "type": "string" },
        "repeat_length": { "type": "number" },
        "material": { "type": "string" },
        "paper_width": { "type": "number" },
        "die_type": { "type": "string" },
        "allocate_meters": { "type": "number" },
        "label_qty": { "type": "number" },
        "core_size": { "type": "string" },
        "qty_per_roll": { "type": "number" },
        "roll_direction": { "type": "string" },
        "remarks": { "type": "string" },
        "status": { "type": "string" },
        "created_date": { "type": "string", "format": "date-time" },
        "created_by": { "type": "string" },
        "created_by_name": { "type": "string" }
      }
    },
    "Job": {
      "title": "Job",
      "description": "Design job definition for material assignment.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "jobId": { "type": "string" },
        "jobName": { "type": "string" },
        "customerName": { "type": "string" },
        "labelWidth": { "type": "number" },
        "labelHeight": { "type": "number" },
        "requiredPaperWidth": { "type": "number" },
        "requiredPaperLength": { "type": "number" },
        "materialType": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdById": { "type": "string" },
        "createdByName": { "type": "string" }
      }
    },
    "Customer": {
      "title": "Customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "gstNumber": { "type": "string" }
      }
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Paper and material vendors.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "gstNumber": { "type": "string" },
        "contactPerson": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" }
      }
    },
    "RollSettings": {
      "title": "RollSettings",
      "type": "object",
      "properties": {
        "parentRollPrefix": { "type": "string" },
        "rollStartNumber": { "type": "number" },
        "childRollPrefixType": { "type": "string" },
        "subChildPrefixType": { "type": "string" },
        "separator": { "type": "string" },
        "barcodePrefix": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/jumbo_stock/{id}",
        "definition": {
          "entityName": "JumboStock",
          "schema": { "$ref": "#/backend/entities/JumboStock" },
          "description": "Inventory of raw jumbo rolls."
        }
      },
      {
        "path": "/production_jobs/{id}",
        "definition": {
          "entityName": "ProductionJob",
          "schema": { "$ref": "#/backend/entities/ProductionJob" },
          "description": "Production Planning jobs released by Design."
        }
      },
      {
        "path": "/jobs/{id}",
        "definition": {
          "entityName": "Job",
          "schema": { "$ref": "#/backend/entities/Job" },
          "description": "Design job definitions."
        }
      },
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles."
        }
      },
      {
        "path": "/adminUsers/{userId}",
        "definition": { "entityName": "User", "schema": { "$ref": "#/backend/entities/User" }, "description": "Admin markers." }
      },
      {
        "path": "/designUsers/{userId}",
        "definition": { "entityName": "User", "schema": { "$ref": "#/backend/entities/User" }, "description": "Design markers." }
      },
      {
        "path": "/productionUsers/{userId}",
        "definition": { "entityName": "User", "schema": { "$ref": "#/backend/entities/User" }, "description": "Production markers." }
      },
      {
        "path": "/settings/{id}",
        "definition": { "entityName": "RollSettings", "schema": { "$ref": "#/backend/entities/RollSettings" }, "description": "App settings." }
      },
      {
        "path": "/suppliers/{id}",
        "definition": { "entityName": "Supplier", "schema": { "$ref": "#/backend/entities/Supplier" }, "description": "Material vendors." }
      }
    ]
  }
}
