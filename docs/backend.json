
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user within the Shree Label ERP system.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "roles": { "type": "array", "items": { "type": "string" } },
        "isActive": { "type": "boolean" },
        "mustChangePassword": { "type": "boolean" },
        "salesCode": { "type": "string" }
      },
      "required": ["id", "email", "firstName", "lastName", "roles", "isActive"]
    },
    "PaperStock": {
      "title": "PaperStock",
      "type": "object",
      "description": "Represents a technical substrate roll in the inventory following the 18-column grid.",
      "properties": {
        "rollNo": { "type": "string", "description": "Auto-generated Unique ID (RL-0001)" },
        "paperCompany": { "type": "string" },
        "paperType": { "type": "string" },
        "widthMm": { "type": "number" },
        "lengthMeters": { "type": "number" },
        "sqm": { "type": "number", "description": "Auto-calculated: (W/1000*L)" },
        "gsm": { "type": "number" },
        "weightKg": { "type": "number" },
        "purchaseRate": { "type": "number" },
        "receivedDate": { "type": "string", "format": "date" },
        "dateOfUsed": { "type": "string", "description": "Updated upon consumption" },
        "jobNo": { "type": "string" },
        "jobSize": { "type": "string" },
        "jobName": { "type": "string" },
        "lotNo": { "type": "string", "description": "Lot / Batch No" },
        "companyRollNo": { "type": "string" },
        "remarks": { "type": "string" }
      },
      "required": ["rollNo", "paperCompany", "widthMm", "lengthMeters", "gsm"]
    },
    "JumboJobCard": {
      "title": "JumboJobCard",
      "type": "object",
      "description": "Production instructions for jumbo roll slitting.",
      "properties": {
        "job_card_no": { "type": "string" },
        "parent_roll": { "type": "string" },
        "child_rolls": { "type": "array", "items": { "type": "string" } },
        "machine": { "type": "string" },
        "operator": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "RUNNING", "COMPLETED"] },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string" },
        "createdById": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" }
    },
    "/paper_stock/{rollId}": {
      "schema": { "$ref": "#/backend/entities/PaperStock" },
      "description": "Primary substrate inventory registry."
    },
    "/jumbo_job_cards/{jobId}": {
      "schema": { "$ref": "#/backend/entities/JumboJobCard" },
      "description": "Jumbo slitting production logs."
    },
    "/roles/{roleId}": {
      "description": "System access roles and granular permissions."
    },
    "/counters/{id}": {
      "description": "Atomic sequence counters for unique ID generation."
    }
  }
}
