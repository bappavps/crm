
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user within the Shree Label ERP system.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "roleId": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "username", "email", "firstName", "lastName", "roleId", "isActive", "createdAt"]
    },
    "JumboStock": {
      "title": "JumboStock",
      "description": "Stores master data for raw jumbo rolls entered via GRN.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "rollNo": { "type": "string" },
        "companyRollNo": { "type": "string" },
        "paperCompany": { "type": "string" },
        "paperType": { "type": "string" },
        "widthMm": { "type": "number" },
        "lengthMeters": { "type": "number" },
        "sqm": { "type": "number" },
        "gsm": { "type": "number" },
        "weightKg": { "type": "number" },
        "purchaseRate": { "type": "number" },
        "wastage": { "type": "number" },
        "dateOfUse": { "type": "string", "format": "date-time" },
        "receivedDate": { "type": "string", "format": "date-time" },
        "jobNo": { "type": "string" },
        "size": { "type": "string" },
        "productName": { "type": "string" },
        "code": { "type": "string" },
        "lotNumber": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "barcode": { "type": "string" },
        "status": { "type": "string", "enum": ["In Stock", "Consumed", "In Production"] },
        "createdById": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "JobPlan": {
      "title": "JobPlan",
      "description": "Master technical production plan from Design.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "master_job_id": { "type": "string" },
        "serial_no": { "type": "string" },
        "order_date": { "type": "string", "format": "date" },
        "planning_status": { "type": "string" },
        "plate_no": { "type": "string" },
        "job_name": { "type": "string" },
        "label_size": { "type": "string" },
        "repeat_length": { "type": "number" },
        "material": { "type": "string" },
        "paper_width": { "type": "number" },
        "die_type": { "type": "string" },
        "allocate_meters": { "type": "number" },
        "label_qty": { "type": "number" },
        "core_size": { "type": "string" },
        "qty_per_roll": { "type": "number" },
        "roll_direction": { "type": "string" },
        "remarks": { "type": "string" },
        "status": { "type": "string" },
        "edit_lock_time": { "type": "string", "format": "date-time" },
        "is_locked": { "type": "boolean" },
        "created_date": { "type": "string", "format": "date-time" },
        "created_by": { "type": "string" },
        "created_by_name": { "type": "string" }
      }
    },
    "JobAuditLog": {
      "title": "JobAuditLog",
      "type": "object",
      "properties": {
        "job_id": { "type": "string" },
        "edited_by": { "type": "string" },
        "edited_by_name": { "type": "string" },
        "edited_date": { "type": "string", "format": "date-time" },
        "field": { "type": "string" },
        "old_value": { "type": "any" },
        "new_value": { "type": "any" }
      }
    },
    "Job": {
      "title": "Job",
      "description": "Master Sales Job entry.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "job_id": { "type": "string" },
        "customer": { "type": "string" },
        "product": { "type": "string" },
        "status": { "type": "string" },
        "created_date": { "type": "string", "format": "date-time" },
        "created_by": { "type": "string" }
      }
    },
    "JobSettings": {
      "title": "JobSettings",
      "type": "object",
      "properties": {
        "jobPrefix": { "type": "string" },
        "yearFormat": { "type": "string" },
        "numberLength": { "type": "number" },
        "separator": { "type": "string" },
        "currentSequence": { "type": "number" }
      }
    },
    "Notification": {
      "title": "Notification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "message": { "type": "string" },
        "jobId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/jumbo_stock/{id}",
        "definition": {
          "entityName": "JumboStock",
          "schema": { "$ref": "#/backend/entities/JumboStock" },
          "description": "Inventory of raw jumbo rolls."
        }
      },
      {
        "path": "/job_planning/{id}",
        "definition": {
          "entityName": "JobPlan",
          "schema": { "$ref": "#/backend/entities/JobPlan" },
          "description": "Master Production Planning jobs released by Design."
        }
      },
      {
        "path": "/job_audit_log/{id}",
        "definition": {
          "entityName": "JobAuditLog",
          "schema": { "$ref": "#/backend/entities/JobAuditLog" },
          "description": "Audit trail for job plan modifications."
        }
      },
      {
        "path": "/jobs/{id}",
        "definition": {
          "entityName": "Job",
          "schema": { "$ref": "#/backend/entities/Job" },
          "description": "Master jobs created by Sales."
        }
      },
      {
        "path": "/job_settings/{id}",
        "definition": {
          "entityName": "JobSettings",
          "schema": { "$ref": "#/backend/entities/JobSettings" },
          "description": "Configuration for unique job numbers."
        }
      },
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles."
        }
      },
      {
        "path": "/notifications/{id}",
        "definition": {
          "entityName": "Notification",
          "schema": { "$ref": "#/backend/entities/Notification" },
          "description": "System alerts and workflow notifications."
        }
      }
    ]
  }
}
