
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents an individual user of the ERP system.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "username", "email", "firstName", "lastName", "role", "status"]
    },
    "JobPost": {
      "title": "JobPost",
      "type": "object",
      "properties": {
        "jobId": { "type": "string" },
        "jobNumber": { "type": "string" },
        "jobType": { "type": "string", "enum": ["New", "Repeat"] },
        "clientName": { "type": "string" },
        "salesUserId": { "type": "string" },
        "salesUserName": { "type": "string" },
        "jobDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string" },
        "adminApproved": { "type": "boolean" },
        "items": {
          "type": "array",
          "items": { "$ref": "#/backend/entities/JobItem" }
        }
      }
    },
    "JobItem": {
      "title": "JobItem",
      "type": "object",
      "properties": {
        "material": { "type": "string" },
        "brand": { "type": "string" },
        "itemName": { "type": "string" },
        "widthMM": { "type": "number" },
        "heightMM": { "type": "number" },
        "core": { "type": "string" },
        "od": { "type": "string" },
        "rollDirection": { "type": "string" },
        "quantity": { "type": "number" },
        "pricePerSqInch": { "type": "number" },
        "totalSqInch": { "type": "number" },
        "costPerLabel": { "type": "number" },
        "totalJobValue": { "type": "number" },
        "artworkUrl": { "type": "string" }
      }
    },
    "PricingConfig": {
      "title": "PricingConfig",
      "type": "object",
      "properties": {
        "sqInchDivider": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/jobs/{jobId}",
        "definition": {
          "entityName": "JobPost",
          "schema": { "$ref": "#/backend/entities/JobPost" },
          "description": "Sales job entries requiring admin approval."
        }
      },
      {
        "path": "/system_settings/pricing_config",
        "definition": {
          "entityName": "PricingConfig",
          "schema": { "$ref": "#/backend/entities/PricingConfig" },
          "description": "Global pricing constants."
        }
      },
      {
        "path": "/counters/job_counter",
        "definition": {
          "entityName": "JobCounter",
          "schema": { "type": "object" },
          "description": "Atomic counter for job IDs."
        }
      }
    ]
  }
}
