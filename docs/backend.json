{
  "entities": {
    "Role": {
      "title": "Role",
      "type": "object",
      "description": "Group permission set.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "permissions": { "type": "object" }
      }
    },
    "User": {
      "title": "User",
      "type": "object",
      "description": "System user with role-based and custom override permissions.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "roleId": { "type": "string" },
        "customPermissions": { "type": "object" },
        "isActive": { "type": "boolean" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/roles/{roleId}": { "schema": { "$ref": "#/backend/entities/Role" }, "description": "Global permission groups." },
    "/users/{userId}": { "schema": { "$ref": "#/backend/entities/User" }, "description": "Master user profiles with overrides." },
    "/jobs/{jobId}": { "schema": { "type": "object" }, "description": "Sales job entries." },
    "/system_settings/pricing_config": { "schema": { "type": "object" }, "description": "Global pricing dividers." },
    "/roll_settings/global_config": { "schema": { "type": "object" }, "description": "Inventory numbering logic." },
    "/counters/{counterId}": { "schema": { "type": "object" }, "description": "Atomic sequence counters." }
  }
}
