
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user within the Shree Label ERP system.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "roleId": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "username", "email", "firstName", "lastName", "roleId", "isActive", "createdAt"]
    },
    "JumboStock": {
      "title": "JumboStock",
      "description": "Stores master data for raw jumbo rolls entered via GRN.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "rollNo": { "type": "string", "description": "Auto-generated ID (JMB-00001)" },
        "companyRollNo": { "type": "string" },
        "paperCompany": { "type": "string" },
        "paperType": { "type": "string" },
        "widthMm": { "type": "number", "default": 1020 },
        "lengthMeters": { "type": "number" },
        "sqm": { "type": "number" },
        "gsm": { "type": "number" },
        "weightKg": { "type": "number" },
        "purchaseRate": { "type": "number" },
        "wastage": { "type": "number" },
        "dateOfUse": { "type": "string", "format": "date-time" },
        "receivedDate": { "type": "string", "format": "date-time" },
        "jobNo": { "type": "string" },
        "size": { "type": "string" },
        "productName": { "type": "string" },
        "code": { "type": "string" },
        "lotNumber": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "barcode": { "type": "string" },
        "status": { "type": "string", "enum": ["In Stock", "Consumed", "In Production"] },
        "createdById": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["rollNo", "paperCompany", "paperType", "widthMm", "lengthMeters", "sqm", "gsm", "weightKg", "status"]
    },
    "Job": {
      "title": "Job",
      "description": "Represents a job created by the Design department for production assignment.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "jobId": { "type": "string" },
        "jobName": { "type": "string" },
        "customerName": { "type": "string" },
        "labelWidth": { "type": "number" },
        "labelHeight": { "type": "number" },
        "requiredPaperWidth": { "type": "number" },
        "requiredPaperLength": { "type": "number" },
        "materialType": { "type": "string" },
        "status": { "type": "string", "enum": ["READY FOR PRODUCTION", "MATERIAL ASSIGNED", "COMPLETED"] },
        "createdById": { "type": "string" },
        "createdByName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["jobId", "jobName", "customerName", "status"]
    },
    "Customer": {
      "title": "Customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "gstNumber": { "type": "string" }
      }
    },
    "Material": {
      "title": "Material",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "gsm": { "type": "number" },
        "ratePerSqMeter": { "type": "number" }
      }
    },
    "RollSettings": {
      "title": "RollSettings",
      "type": "object",
      "properties": {
        "parentRollPrefix": { "type": "string" },
        "rollStartNumber": { "type": "number" },
        "childRollPrefixType": { "type": "string", "enum": ["Alphabet"] },
        "subChildPrefixType": { "type": "string", "enum": ["Number"] },
        "separator": { "type": "string" },
        "barcodePrefix": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/jumbo_stock/{jumboId}",
        "definition": {
          "entityName": "JumboStock",
          "schema": { "$ref": "#/backend/entities/JumboStock" },
          "description": "Inventory of raw jumbo rolls."
        }
      },
      {
        "path": "/jobs/{jobId}",
        "definition": {
          "entityName": "Job",
          "schema": { "$ref": "#/backend/entities/Job" },
          "description": "Job assignments created by Design."
        }
      },
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles."
        }
      },
      {
        "path": "/adminUsers/{userId}",
        "definition": { "entityName": "User", "schema": { "$ref": "#/backend/entities/User" }, "description": "Admin role markers." }
      },
      {
        "path": "/designUsers/{userId}",
        "definition": { "entityName": "User", "schema": { "$ref": "#/backend/entities/User" }, "description": "Design department marker." }
      },
      {
        "path": "/productionUsers/{userId}",
        "definition": { "entityName": "User", "schema": { "$ref": "#/backend/entities/User" }, "description": "Production department marker." }
      },
      {
        "path": "/customers/{customerId}",
        "definition": { "entityName": "Customer", "schema": { "$ref": "#/backend/entities/Customer" }, "description": "Master customer data." }
      },
      {
        "path": "/materials/{materialId}",
        "definition": { "entityName": "Material", "schema": { "$ref": "#/backend/entities/Material" }, "description": "Master material data." }
      },
      {
        "path": "/settings/{settingId}",
        "definition": { "entityName": "RollSettings", "schema": { "$ref": "#/backend/entities/RollSettings" }, "description": "Global application settings." }
      },
      {
        "path": "/inventoryItems/{id}",
        "definition": { "entityName": "object", "schema": { "type": "object" }, "description": "Derived stock items (Slitted, FG)." }
      }
    ]
  }
}
