
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "System user with role-based permissions.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "roleId": { "type": "string", "enum": ["Admin", "Sales", "Manager", "Operator"] },
        "isActive": { "type": "boolean" }
      }
    },
    "JobPost": {
      "title": "JobPost",
      "type": "object",
      "description": "Production job submitted by sales requiring admin approval.",
      "properties": {
        "jobId": { "type": "string" },
        "jobNumber": { "type": "string" },
        "jobType": { "type": "string" },
        "clientName": { "type": "string" },
        "salesUserName": { "type": "string" },
        "status": { "type": "string" },
        "adminApproved": { "type": "boolean" },
        "items": {
          "type": "array",
          "items": { "$ref": "#/backend/entities/JobItem" }
        }
      }
    },
    "JobItem": {
      "title": "JobItem",
      "type": "object",
      "properties": {
        "material": { "type": "string" },
        "itemName": { "type": "string" },
        "widthMM": { "type": "number" },
        "heightMM": { "type": "number" },
        "quantity": { "type": "number" },
        "pricePerSqInch": { "type": "number" },
        "totalJobValue": { "type": "number" },
        "artworkUrl": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": { "schema": { "$ref": "#/backend/entities/User" }, "description": "Master user profiles." },
    "/jobs/{jobId}": { "schema": { "$ref": "#/backend/entities/JobPost" }, "description": "Sales job entries." },
    "/system_settings/pricing_config": { "schema": { "type": "object" }, "description": "Global pricing dividers." },
    "/roll_settings/global_config": { "schema": { "type": "object" }, "description": "Inventory numbering logic." },
    "/counters/{counterId}": { "schema": { "type": "object" }, "description": "Atomic sequence counters." }
  }
}
