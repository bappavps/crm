
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user within the Shree Label ERP system.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "roles": { "type": "array", "items": { "type": "string" } },
        "isActive": { "type": "boolean" },
        "mustChangePassword": { "type": "boolean" },
        "salesCode": { "type": "string" }
      },
      "required": ["id", "email", "firstName", "lastName", "roles", "isActive"]
    },
    "PaperStock": {
      "title": "PaperStock",
      "type": "object",
      "description": "Represents a raw substrate jumbo roll in the inventory with 19 technical columns.",
      "properties": {
        "rollNo": { "type": "string", "description": "Unique Roll ID" },
        "receivedDate": { "type": "string", "format": "date" },
        "jobNo": { "type": "string" },
        "paperCompany": { "type": "string" },
        "paperType": { "type": "string" },
        "gsm": { "type": "number" },
        "size": { "type": "string" },
        "widthMm": { "type": "number" },
        "lengthMeters": { "type": "number" },
        "quantity": { "type": "number" },
        "sqm": { "type": "number", "description": "Auto-calculated area" },
        "lotNo": { "type": "string" },
        "productName": { "type": "string" },
        "code": { "type": "string" },
        "status": { "type": "string", "enum": ["Available", "Reserved", "Partial", "Consumed"] },
        "location": { "type": "string" },
        "supplier": { "type": "string" },
        "createdByName": { "type": "string" },
        "remarks": { "type": "string" }
      },
      "required": ["rollNo", "paperCompany", "gsm", "widthMm", "lengthMeters", "quantity"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Employee profiles and access control."
    },
    "/paper_stock/{rollId}": {
      "schema": { "$ref": "#/backend/entities/PaperStock" },
      "description": "Main substrate inventory registry with 19 technical columns."
    },
    "/adminUsers/{adminUid}": {
      "schema": { "type": "object" },
      "description": "Authorization markers for system administrators."
    }
  }
}
